# Accurate Online API credentials
# Get these from: https://account.accurate.id/developer
ACCURATE_CLIENT_ID=your_client_id_here
ACCURATE_CLIENT_SECRET=your_client_secret_here
ACCURATE_ACCESS_TOKEN=your_access_token_here

# These are filled in after calling get_accurate_session()
ACCURATE_SESSION_ID=your_session_id_here
ACCURATE_HOST=https://public.accurate.id
